                        </ui:VisualElement>
                        <ui:VisualElement name="signo" class="operadoresCont" style="flex-grow: 1;">
                            <ui:Label text="÷" name="txt-signo" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; font-size: 100%; color: rgb(0, 180, 255); -unity-font-style: bold; -unity-text-outline-width: 0; letter-spacing: 0; text-shadow: 3px 1px 0 rgb(122, 221, 216); background-color: rgba(0, 0, 0, 0); -unity-font-definition: url(&quot;project://database/Assets/UI%20Toolkit/UnityThemes/UnityDefaultRuntimeTheme.tss?fileID=2230732570650464555&amp;guid=7987568297664ed4ab6720ca4aa32220&amp;type=3#NotInter-Regular&quot;);"/>
                        </ui:VisualElement>
                        <ui:VisualElement name="divisor" class="operadoresCont" style="flex-grow: 1;">
                            <ui:Label text="00" name="txt-divisor" style="background-color: rgba(0, 0, 0, 0); font-size: 70%; color: rgb(255, 255, 255); -unity-font-style: bold; -unity-font-definition: url(&quot;project://database/Assets/Fonts/BebasNeue-Regular.ttf?fileID=12800000&amp;guid=1c37a6b70989a864e88473b93c5d8293&amp;type=3#BebasNeue-Regular&quot;);"/>
                        </ui:VisualElement>
                        <ui:VisualElement name="igual" class="operadoresCont" style="flex-grow: 1;">
                            <ui:Label text="=&#10;" name="txt-igual" style="background-color: rgba(0, 0, 0, 0); font-size: 70%; color: rgb(65, 168, 190); -unity-font-style: bold; -unity-font-definition: url(&quot;project://database/Assets/Fonts/BebasNeue-Regular.ttf?fileID=12800000&amp;guid=1c37a6b70989a864e88473b93c5d8293&amp;type=3#BebasNeue-Regular&quot;);"/>
                        </ui:VisualElement>
                        <ui:VisualElement name="resultado" class="operadoresCont" style="flex-grow: 1;">
                            <ui:Label text="0" name="txt-resultado" style="background-color: rgba(0, 0, 0, 0); font-size: 70%; color: rgb(255, 255, 255); -unity-font-style: bold; -unity-font-definition: url(&quot;project://database/Assets/Fonts/BebasNeue-Regular.ttf?fileID=12800000&amp;guid=1c37a6b70989a864e88473b93c5d8293&amp;type=3#BebasNeue-Regular&quot;);"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement name="cDivisionesRealizadas" class="divisionesRealizadas" style="flex-grow: 1;">
                    <ui:Label text="Operaciones Existosas" style="-unity-text-align: middle-center; color: rgb(255, 255, 255); font-size: 20px; -unity-font-definition: url(&quot;project://database/Assets/Fonts/Lexend-VariableFont_wght.ttf?fileID=12800000&amp;guid=fb67724670071f9488997379caef1f61&amp;type=3#Lexend-VariableFont_wght&quot;); -unity-font-style: bold;"/>
                    <ui:VisualElement name="resueltos" class="divisiones" style="flex-grow: 1;">
                        <ui:VisualElement name="contenedorOperacion1" enabled="true" class="listaElementos" style="flex-grow: 1;">
                            <ui:Label text=" " name="txt-operacion1" class="textosOpR"/>
                            <ui:Label text="" name="txt-bien-mal1" class="textoMarca" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; font-size: 40px; height: 100%; -unity-font-definition: url(&quot;project://database/Assets/Fonts/GROBOLD.ttf?fileID=12800000&amp;guid=7ae43624891dfe0418c716074663170f&amp;type=3#GROBOLD&quot;); -unity-text-align: middle-center;"/>
                        </ui:VisualElement>
                        <ui:VisualElement name="contenedorOperacion2" enabled="true" class="listaElementos" style="flex-grow: 1;">
                            <ui:Label text=" " name="txt-operacion2" class="textosOpR"/>
                            <ui:Label text="" name="txt-bien-mal1" class="textoMarca" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; font-size: 40px; height: 100%; -unity-font-definition: url(&quot;project://database/Assets/Fonts/GROBOLD.ttf?fileID=12800000&amp;guid=7ae43624891dfe0418c716074663170f&amp;type=3#GROBOLD&quot;); -unity-text-align: middle-center;"/>
                        </ui:VisualElement>
                        <ui:VisualElement name="contenedorOperacion3" enabled="true" class="listaElementos" style="flex-grow: 1;">
                            <ui:Label text=" " name="txt-operacion3" class="textosOpR"/>
                            <ui:Label text="" name="txt-bien-mal1" class="textoMarca" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; font-size: 40px; height: 100%; -unity-font-definition: url(&quot;project://database/Assets/Fonts/GROBOLD.ttf?fileID=12800000&amp;guid=7ae43624891dfe0418c716074663170f&amp;type=3#GROBOLD&quot;); -unity-text-align: middle-center;"/>
                        </ui:VisualElement>
                        <ui:VisualElement name="contenedorOperacion4" enabled="true" class="listaElementos" style="flex-grow: 1;">
                            <ui:Label text=" " name="txt-operacion4" class="textosOpR"/>
                            <ui:Label text="" name="txt-bien-mal1" class="textoMarca" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; font-size: 40px; height: 100%; -unity-font-definition: url(&quot;project://database/Assets/Fonts/GROBOLD.ttf?fileID=12800000&amp;guid=7ae43624891dfe0418c716074663170f&amp;type=3#GROBOLD&quot;); -unity-text-align: middle-center;"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="ContenidoDerecho" class="contenidoDerecho" style="flex-grow: 1;">
                <ui:VisualElement name="cNotas" class="cNotas" style="flex-grow: 1; border-left-color: rgb(140, 95, 28); border-right-color: rgb(140, 95, 28); border-top-color: rgb(140, 95, 28); border-bottom-color: rgb(140, 95, 28);">
